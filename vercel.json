{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "projectmanager": {
      "root": ".",
      "runtime": "node",
      "entrypoint": "server.js"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "projectmanager"
      }
    }
  ]
}
